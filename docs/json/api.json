  },
  "components": {
    "schemas": {
      "UpdateProfileDTO": {
        "type": "object",
        "description": "个人角色画像更新模型",
        "properties": {
          "ageGroup": {
            "type": "integer",
            "format": "int32",
            "description": "年龄段: 1=儿童 2=青壮年 3=老年",
            "example": 2,
            "maximum": 3,
            "minimum": 1
          },
          "gender": {
            "type": "integer",
            "format": "int32",
            "description": "性别: 1=男 2=女",
            "example": 1,
            "maximum": 2,
            "minimum": 1
          },
          "occupation": {
            "type": "string",
            "description": "职业",
            "example": "财务人员"
          }
        }
      },
      "ResultVoid": {
        "type": "object",
        "description": "统一响应包装模型",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "状态码: 200=成功, 其余为异常码",
            "example": 200
          },
          "message": {
            "type": "string",
            "description": "提示信息",
            "example": "success"
          },
          "data": {
            "type": "object",
            "description": "具体的业务数据内容"
          }
        }
      },
      "UpdateConfigDTO": {
        "type": "object",
        "description": "风险配置更新模型",
        "properties": {
          "riskPreference": {
            "type": "integer",
            "format": "int32",
            "description": "风险灵敏度: 1=低 2=中 3=高",
            "example": 2,
            "maximum": 3,
            "minimum": 1
          },
          "riskThreshold": {
            "type": "number",
            "description": "风险分阈值 (0~100)，超过此分值触发预警",
            "example": 75.5,
            "maximum": 100,
            "minimum": 0
          },
          "interventionStrategy": {
            "type": "integer",
            "format": "int32",
            "description": "干预策略: 1=弹窗提醒 2=语音阻断 3=自动联系监护人",
            "example": 1,
            "maximum": 3,
            "minimum": 1
          }
        }
      },
      "UpdateNotifyPolicyDTO": {
        "type": "object",
        "description": "监护人通知偏好设置模型",
        "properties": {
          "notifyPolicy": {
            "type": "integer",
            "format": "int32",
            "description": "通知策略: 1=实时推送 2=周期汇总",
            "example": 1,
            "maximum": 2,
            "minimum": 1
          }
        },
        "required": [
          "notifyPolicy"
        ]
      },
      "RegisterDTO": {
        "type": "object",
        "description": "用户注册请求体",
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名 (3~50字)",
            "example": "zhangsan",
            "maxLength": 50,
            "minLength": 3
          },
          "password": {
            "type": "string",
            "description": "密码 (至少6位)",
            "example": 123456,
            "maxLength": 100,
            "minLength": 6
          }
        },
        "required": [
          "password",
          "username"
        ]
      },
      "ResultString": {
        "type": "object",
        "description": "统一响应包装模型",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "状态码: 200=成功, 其余为异常码",
            "example": 200
          },
          "message": {
            "type": "string",
            "description": "提示信息",
            "example": "success"
          },
          "data": {
            "type": "string",
