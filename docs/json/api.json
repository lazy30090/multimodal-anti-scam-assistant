{
  "openapi": "3.1.0",
  "info": {
    "title": "多模态反诈智能助手 API",
    "description": "后端接口文档，含用户、监护人、预警、报告等模块",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8081",
      "description": "Generated server url"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "4. 智能对话模块",
      "description": "处理多模态反诈咨询对话，支持文本、图片、语音及链接输入"
    },
    {
      "name": "7. 安全报告模块",
      "description": "生成并查看多维度的反诈监测定期报告"
    },
    {
      "name": "1. 用户与角色管理",
      "description": "处理用户注册、登录、个人画像及风险配置"
    },
    {
      "name": "2. 监护人联动管理",
      "description": "处理监护人端（小程序）的登录、绑定关系、白名单、安全周报及远程干预"
    },
    {
      "name": "5. 多模态检测模块",
      "description": "提供单次消息检测及批量测评自动化工具，支持文本、图片及语音"
    },
    {
      "name": "3. 风险预警模块",
      "description": "处理风险历史记录查询及详细判定依据展示"
    },
    {
      "name": "6. 知识库进化模块",
      "description": "支持上传多模态诈骗案例，驱动算法模型的知识增量学习与进化"
    }
  ],
  "paths": {
    "/api/user/profile": {
      "get": {
        "tags": [
          "1. 用户与角色管理"
        ],
        "summary": "获取个人画像",
        "description": "获取当前用户的角色属性（年龄、职业等）及已绑定的监护人列表",
        "operationId": "getProfile",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultUserVO"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "1. 用户与角色管理"
        ],
        "summary": "更新角色属性",
        "description": "修改年龄段、性别、职业等非安全配置属性",
        "operationId": "updateProfile",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
