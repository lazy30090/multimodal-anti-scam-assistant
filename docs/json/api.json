    },
    "/api/knowledge/upload": {
      "post": {
        "tags": [
          "6. 知识库进化模块"
        ],
        "summary": "提交新诈骗案例",
        "description": "上传包含最新诈骗套路的文件（文本、图片、音视频等），提交后系统将异步触发特征提取与向量化入库，提升 AI 的识别精准度。",
        "operationId": "upload",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "多模态案例文件"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultString"
                }
              }
            }
          }
        }
      }
    },
